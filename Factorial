import java.util.*;




class Main {
    static int fact(int n){
    int result = 1;
    for (int i=1 ; i<=n ;i++){
        result * =i;
    }
    return result;
    
}
    public static void main(String[] args) {
        
        Scanner ip = new Scanner(System.in);
       
        int op =  ip.nextInt();
        
        System.out.println(fact(op));
        
    
      
    }
}
