import java.util.Scanner;

public class Main {


    static void PrimeFactor(int n){

        int i=2;

        while(i*i<=n){
            while(n%i==0){
                System.out.println(i);
                n=n/i;
            }
            i++;
        }

        if(n>1){
            System.out.println(n);
        }


    }


    static void main() {
        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();

        PrimeFactor(n);

    }
}
