import java.util.*;


public class Main{

    static int trailingzeros(int n){
        int res = 0;
        int powerof5 = 5;
        while (n<=powerof5){
            res = res + (n/powerof5);
            powerof5 = powerof5*5;

        }
        return res;

    }


    public static void main(String[] args){
        Scanner scan  = new Scanner(System.in);

        int ip = scan.nextInt();


            System.out.println(trailingzeros(ip));




    }
}
