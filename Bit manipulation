import java.util.Scanner;

public class Main{


    static  String decimalToBinary(int n){

        String b = "" ;

        while(n>=1){

            int x = n%2;
            n= n/2;
            b= x+b;
        }

        return b;

    }

    static void main() {

        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        System.out.println(decimalToBinary(n));

    }
}
