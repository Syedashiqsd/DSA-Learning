import java.util.Scanner;

public class Main {

    static boolean isprime(int n){

        for(int i =2 ; i<=
                Math.sqrt(n);i++){
            if(n%i==0){
                return  false;
            }
        }
        return true;
    }




    static void main() {

        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        System.out.println(isprime(n));

    }
}
