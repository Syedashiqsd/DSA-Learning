import java.util.*;

class Main {
    static int euclidgcd(int a , int b){

     while(a!= 0 && b!=0){
         if(a>b){
             a= a%b;
         }else {
             b= b%a;
         }
     }
     if(a!=0){
         return  a;
     }else {
         return  b;
     }
    }

 public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        int a = scan.nextInt();
        int b= scan.nextInt();

        System.out.println(euclidgcd(a,b));


    }
}
